# OpenAI (server-side — never commit real keys)
OPENAI_API_KEY=

# Supabase (https://supabase.com/dashboard — Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Storage: create bucket in Supabase → Storage (default name `brand-assets`), public read, auth write
# NEXT_PUBLIC_SUPABASE_BRAND_BUCKET=brand-assets

# Support (optional — WhatsApp: country + number, digits only e.g. 919876543210)
NEXT_PUBLIC_SUPPORT_WHATSAPP=
NEXT_PUBLIC_SUPPORT_EMAIL=

# Canonical site URL after you connect custom domain (no trailing slash)
# NEXT_PUBLIC_SITE_URL=https://growurb.com
