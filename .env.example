# OpenAI (server-side — never commit real keys)
OPENAI_API_KEY=

# Supabase (https://supabase.com/dashboard — Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Storage: create bucket in Supabase → Storage (default name `brand-assets`), public read, auth write
# NEXT_PUBLIC_SUPABASE_BRAND_BUCKET=brand-assets

# Support (optional — WhatsApp: country + number, digits only e.g. 919876543210)
NEXT_PUBLIC_SUPPORT_WHATSAPP=
NEXT_PUBLIC_SUPPORT_EMAIL=team.growurb@gmail.com
NEXT_PUBLIC_SUPPORT_PHONE=+91 8107367659

# Legal / compliance (optional overrides — defaults are set in lib/site-legal.ts)
NEXT_PUBLIC_LEGAL_ENTITY_NAME=Growurb AI
NEXT_PUBLIC_LEGAL_ADDRESS=Village Manai, City Jodhpur, State Rajasthan, India
NEXT_PUBLIC_LEGAL_OPERATING_REGION=Jodhpur, Rajasthan, India

# Contact form email (optional — uses Resend; falls back to server log without API key)
RESEND_API_KEY=
RESEND_FROM_EMAIL=GrowUrb AI <billing@yourdomain.com>
CONTACT_TO_EMAIL=

# Canonical site URL after you connect custom domain (no trailing slash)
# NEXT_PUBLIC_SITE_URL=https://growurb.com

# Stripe (https://dashboard.stripe.com — Developers → API keys & Webhooks)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Recurring price IDs from Products → each plan → Pricing → Price ID (price_...)
STRIPE_PRICE_GROWTH_PRO=
STRIPE_PRICE_AGENCY=

# Supabase service role — webhooks only (Project Settings → API → service_role). Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=
